{
  "manifest_version": 3,
  "name": "YouTube Pin",
  "version": "1.0",
  "description": "Always pins a video as the first YouTube recommendation",
  "permissions": ["storage", "identity"],
  "host_permissions": ["https://qur-8.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "oauth2": {
    "client_id": "30247318055-glh9i09aql9hiomia2rt8jqi2o2iu0a9.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/youtube.readonly"]
  },
  "web_accessible_resources": [
    {
      "resources": ["videos.json"],
      "matches": ["*://www.youtube.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
