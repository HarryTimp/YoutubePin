{
  "manifest_version": 3,
  "key": "",
  "name": "YouTube Pin",
  "version": "1.158",
  "description": "Always pins a video as the first YouTube recommendation",
  "permissions": ["storage", "identity", "identity.email", "scripting"],
  "host_permissions": ["https://qur-8.com/*", "https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["videos.json", "injected.js"],
      "matches": ["*://www.youtube.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
